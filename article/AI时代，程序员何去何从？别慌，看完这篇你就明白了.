**场景2：写一个复杂的数据处理脚本**

> 📝 给AI的提示词：
> 用Python写一个数据处理的脚本：
> 1. 从MySQL读取订单数据（order表）
> 2. 清洗数据：过滤异常订单（金额<=0或>=100000）
> 3. 按用户ID分组，计算每个用户的：
>    - 订单总数
>    - 订单总金额
>    - 平均订单金额
>    - 最后下单时间
> 4. 将结果写入Redis缓存，key格式：user:order:stats:{userId}
> 5. 设置过期时间为24小时
> 请包含完整的代码和必要的异常处理。

**🤖 AI给出的代码：**

```python
import pymysql
from redis import Redis
from datetime import datetime
from typing import Dict, List
import logging

logging.basicConfig(level=logging.INFO)
logger = logging.getLogger(__name__)


class OrderStatsProcessor:
    def __init__(self):
        self.mysql_conn = pymysql.connect(
            host='localhost',
            user='root',
            password='password',
            database='order_db'
        )
        self.redis_client = Redis(host='localhost', port=6379, db=0)

    def fetch_orders(self) -> List[Dict]:
        """从MySQL读取订单数据"""
        sql = """
            SELECT user_id, order_id, amount, create_time
            FROM orders
            WHERE status = 1 AND create_time >= DATE_SUB(NOW(), INTERVAL 90 DAY)
        """
        with self.mysql_conn.cursor(pymysql.cursors.DictCursor) as cursor:
            cursor.execute(sql)
            return cursor.fetchall()

    def clean_data(self, orders: List[Dict]) -> List[Dict]:
        """清洗数据：过滤异常订单"""
        cleaned = []
        for order in orders:
            if 0 < order['amount'] < 100000:
                cleaned.append(order)
            else:
                logger.warning(f"过滤异常订单: order_id={order['order_id']}, amount={order['amount']}")
        return cleaned

    def calculate_stats(self, orders: List[Dict]) -> Dict[int, Dict]:
        """按用户分组统计"""
        user_stats = {}
        
        for order in orders:
            user_id = order['user_id']
            
            if user_id not in user_stats:
                user_stats[user_id] = {
                    'order_count': 0,
                    'total_amount': 0.0,
                    'last_order_time': None
                }
            
            stats = user_stats[user_id]
            stats['order_count'] += 1
            stats['total_amount'] += float(order['amount'])
            
            # 更新最后下单时间
            if stats['last_order_time'] is None or \
               order['create_time'] > stats['last_order_time']:
                stats['last_order_time'] = order['create_time']
        
        # 计算平均值
        for user_id, stats in user_stats.items():
            if stats['order_count'] > 0:
                stats['avg_amount'] = round(stats['total_amount'] / stats['order_count'], 2)
            stats['total_amount'] = round(stats['total_amount'], 2)
        
        return user_stats

    def save_to_redis(self, user_stats: Dict[int, Dict]):
        """保存到Redis"""
        for user_id, stats in user_stats.items():
            key = f"user:order:stats:{user_id}"
            self.redis_client.setex(
                key,
                3600 * 24,  # 24小时过期
                str(stats)
            )
            logger.info(f"已缓存用户 {user_id} 的统计数据")

    def process(self):
        """主处理流程"""
        try:
            logger.info("开始处理订单数据...")
            
            # 1. 读取数据
            orders = self.fetch_orders()
            logger.info(f"读取到 {len(orders)} 条订单")
            
            # 2. 清洗数据
            cleaned_orders = self.clean_data(orders)
            logger.info(f"清洗后剩余 {len(cleaned_orders)} 条有效订单")
            
            # 3. 统计计算
            user_stats = self.calculate_stats(cleaned_orders)
            logger.info(f"计算了 {len(user_stats)} 个用户的统计")
            
            # 4. 写入Redis
            self.save_to_redis(user_stats)
            
            logger.info("处理完成！")
            
        except Exception as e:
            logger.error(f"处理失败: {str(e)}")
            raise
        finally:
            self.mysql_conn.close()


if __name__ == "__main__":
    processor = OrderStatsProcessor()
    processor.process()
```

**✅ 评价**：代码完整、结构清晰、有异常处理，基本可以直接使用！

